# LeetCode Configuration Environment Variables Template

# Copy cookies from leetcode website and place them here:
LEETCODE_SESSION=your_leetcode_session_here
LEETCODE_CSRF_TOKEN=your_csrftoken_here

# Optional configuration:
# LEETCODE_DOMAIN=leetcode.com
# LEETCODE_DELAY=1.0

# Automatically updated sync state (Do not edit unless resetting sync):
# LEETCODE_LAST_SYNCED_TIMESTAMP=0
